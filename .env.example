# Optional Docker Compose overrides
# Copy to .env only if you want to override defaults.

# APP_MODE is set automatically by run-docker.sh (dev/prod)
APP_MODE=dev

# server env file used by docker-compose
SERVER_ENV_FILE=./server/.env

# optional explicit model URL override for server container
MODEL_BASE_URL=http://model:5000

# prod-only: prebuilt model artifact image with files inside MODEL_ARTIFACTS_PATH
# Example: ghcr.io/your-org/auth-model-artifacts:2026-03-23
MODEL_ARTIFACT_IMAGE=

# path inside MODEL_ARTIFACT_IMAGE where trained files live
MODEL_ARTIFACTS_PATH=/artifacts
